# === AI Provider Keys ===
# At least ONE of these must be set:
OPENAI_API_KEY=
GEMINI_API_KEY=
CLAUDE_API_KEY=
DEEPSEEK_API_KEY=
MISTRAL_API_KEY=

# === RAG Playground Configuration (optional) ===
# Provider to use: gemini (default), openai, claude, deepseek, mistral
RAG_LLM_PROVIDER=gemini
# Chat model (gemini-flash-latest-flash recommended for Gemini free tier)
RAG_LLM_MODEL=gemini-2.5-flash
# Embedding model (gemini-embedding-001 for Gemini, text-embedding-3-small for OpenAI)
RAG_EMBEDDING_MODEL=gemini-embedding-001

# === Infrastructure ===
MONGO_URI=mongodb://localhost:27017/
MONGO_DB=ai_commerce
# Qdrant defaults to http://localhost:6333
# Redis defaults to redis://localhost:6379/0
